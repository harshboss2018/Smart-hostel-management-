## Backend (Express) env vars (set in Render backend service)
NODE_ENV=production
PORT=5000
MONGO_URI=your_mongodb_connection_string

# Allow your deployed frontend origin (comma-separated list supported).
# Example:
# CORS_ORIGIN=https://your-frontend.onrender.com
CORS_ORIGIN=

# Only set to true if you're using cookie-based auth.
CORS_CREDENTIALS=false

